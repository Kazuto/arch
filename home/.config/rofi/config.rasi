configuration {
  modi: "drun,run,window";
  font: "JetBrainsMono Nerd Font 12";
  show-icons: true;
  icon-theme: "Papirus";
  terminal: "ghostty";
  drun-display-format: "{icon} {name}";
  location: 0;
  disable-history: false;
  hide-scrollbar: true;
  display-drun: " ";
  display-run: " ";
  display-window: " ";
  sidebar-mode: true;
}

@theme "~/.config/rofi/themes/drun.rasi"
