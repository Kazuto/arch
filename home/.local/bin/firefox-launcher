#!/usr/bin/env bash

# Get the currently focused window's class
focused_class=$(hyprctl activewindow -j 2>/dev/null | jq -r '.class' 2>/dev/null)

# If rofi or another menu is focused, get the previously focused window
if [[ "$focused_class" == "rofi" ]] || [[ -z "$focused_class" ]]; then
    # Get all clients and find the most recently focused Firefox window
    focused_class=$(hyprctl clients -j 2>/dev/null | jq -r '[.[] | select(.class | startswith("firefox"))] | sort_by(.focusHistoryID) | reverse | .[0].class // ""' 2>/dev/null)
fi

# Variable to track which Firefox class to focus
target_class=""

# Check if a Firefox window is focused
if [[ "$focused_class" == "firefox-work" ]]; then
    # Open in Work profile (without --no-remote so it uses existing instance)
    firefox -P "Work" --new-tab "$@"
    target_class="firefox-work"
elif [[ "$focused_class" == "firefox-personal" ]]; then
    # Open in Personal profile (without --no-remote so it uses existing instance)
    firefox -P "Personal" --new-tab "$@"
    target_class="firefox-personal"
elif [[ "$focused_class" =~ ^firefox ]]; then
    # Generic firefox window, try to reuse it
    firefox --new-tab "$@"
    target_class="$focused_class"
else
    # No Firefox focused, check which instances are running
    work_running=$(pgrep -f "firefox.*-P Work" || true)
    personal_running=$(pgrep -f "firefox.*-P Personal" || true)

    if [[ -n "$work_running" ]]; then
        # Work profile is running, use it
        firefox -P "Work" --new-tab "$@"
        target_class="firefox-work"
    elif [[ -n "$personal_running" ]]; then
        # Personal profile is running, use it
        firefox -P "Personal" --new-tab "$@"
        target_class="firefox-personal"
    else
        # No profiles running, open with default
        firefox --new-tab "$@"
    fi
fi

# Focus the Firefox window if we know which one to focus
if [[ -n "$target_class" ]]; then
    # Map the expected class to workspace ID (since Firefox doesn't respect --class properly)
    workspace_id=""

    if [[ "$target_class" == "firefox-work" ]]; then
        # Work profile should be on workspace 1
        workspace_id=$(hyprctl clients -j 2>/dev/null | jq -r '.[] | select(.class == "firefox" and .workspace.id == 1) | .workspace.id' 2>/dev/null | head -n1)
    elif [[ "$target_class" == "firefox-personal" ]]; then
        # Personal profile should be on workspace 5
        workspace_id=$(hyprctl clients -j 2>/dev/null | jq -r '.[] | select(.class == "firefox" and .workspace.id == 5) | .workspace.id' 2>/dev/null | head -n1)
    else
        # For generic firefox, try to find it
        workspace_id=$(hyprctl clients -j 2>/dev/null | jq -r ".[] | select(.class == \"firefox\") | .workspace.id" 2>/dev/null | head -n1)
    fi

    # Switch to the workspace
    if [[ -n "$workspace_id" ]] && [[ "$workspace_id" != "null" ]] && [[ "$workspace_id" != "" ]]; then
        hyprctl dispatch workspace "$workspace_id"
        # Small delay to let workspace switch complete
        sleep 0.1
    fi
fi
